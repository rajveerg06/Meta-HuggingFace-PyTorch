# ─────────────────────────────────────────────────────────────────────────────
# OpenEnv Invoice/Receipt Environment — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required for inference.py ─────────────────────────────────────────────────
# Base URL of the OpenAI-compatible inference API endpoint
# e.g. https://api-inference.huggingface.co/v1
API_BASE_URL=

# Model identifier served at API_BASE_URL
# e.g. meta-llama/Meta-Llama-3.1-8B-Instruct
MODEL_NAME=

# Hugging Face token (used as API key for HF Inference Endpoints)
HF_TOKEN=

# ── Server configuration ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=7860

# Data root directory (default: data/)
DATA_ROOT=data

# Default random seed for reproducible runs
SEED=42

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
