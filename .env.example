# ─────────────────────────────────────────────────────────
# OpenEnv Invoice/Receipt Environment — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# OpenAI API key (required only for the LLM-based agent)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI model to use for the LLM agent (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Data root directory (default: data/)
DATA_ROOT=data

# Server configuration
HOST=0.0.0.0
PORT=7860

# Default random seed for reproducible runs
SEED=42

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
